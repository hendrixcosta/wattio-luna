# ============================================================
# wattio-Luna — variáveis de ambiente
# Copie para .env e preencha. NUNCA versione o .env real.
# ============================================================

# Porta exposta no host
PORT=8080

# --- Autenticação da API ---
# Uma ou mais chaves separadas por vírgula. Gere com: openssl rand -hex 32
LUNA_API_KEYS=troque-esta-chave,outra-chave-opcional

# --- Claude Code: escolha UMA forma de autenticação ---
# (A) Assinatura Pro/Max (mesmos limites do VS Code, recomendado para uso interno).
#     Na sua máquina logada rode `claude setup-token` e cole o token sk-ant-oat... aqui.
#     Quando preenchido, a ANTHROPIC_API_KEY abaixo é IGNORADA.
CLAUDE_CODE_OAUTH_TOKEN=
# (B) API key pay-per-token (https://console.anthropic.com) — sujeita ao rate limit do tier.
ANTHROPIC_API_KEY=sk-ant-...

# Modelo usado pela Luna. Opções: claude-sonnet-4-6 (padrão, custo/benefício),
# claude-opus-4-8 (mais capaz), claude-haiku-4-5-20251001 (mais barato).
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Repositório a ser analisado (clonado localmente) ---
# URL do repositório Git que a Luna vai ler. Ex.: https://github.com/wattio/billing.git
GIT_REPO_URL=https://github.com/watt-io/gera.git
# Branch a clonar (vazio = branch padrão do remoto).
GIT_BRANCH=master

# Auth de LEITURA para repositórios privados (https):
#   - GIT_USERNAME: no GitHub use "x-access-token" (padrão); no GitLab use "oauth2".
#   - GIT_TOKEN: PAT/deploy token SOMENTE LEITURA. Deixe vazio se o repo for público.
# O token é fornecido ao git via askpass e NÃO é persistido no disco.
GIT_USERNAME=x-access-token
GIT_TOKEN=github_pat_TROQUE_POR_SEU_TOKEN_DE_LEITURA

# --- Atualização do repositório ---
# Faz `git pull` antes de cada chamado (respeitando o intervalo mínimo abaixo).
REPO_PULL_ON_REQUEST=false
# Intervalo mínimo entre pulls (ms) para não atualizar a cada requisição.
REPO_PULL_MIN_INTERVAL_MS=30000

# --- Limites de execução ---
CLAUDE_TIMEOUT_MS=180000
CLAUDE_MAX_TURNS=30
# Tamanho máximo do relato do chamado (caracteres).
MAX_TICKET_LENGTH=4000

# ============================================================
# MCP: wattio-mcp (OpenSearch de tarefas operacionais)
# ============================================================
# URL do MCP que a Luna consulta (transporte HTTP, endpoint /mcp).
# - No compose, deixe o padrão para usar o serviço wattio-mcp local.
# - Para usar o MCP hospedado: https://mcp.wattio.com.br/mcp
# - Vazio desliga o MCP (a Luna passa a analisar só o código local).
MCP_WATTIO_URL=http://wattio-mcp:8000/mcp

# --- Credenciais do OpenSearch usadas pelo serviço wattio-mcp ---
OPENSEARCH_URL=https://search-seu-dominio.us-east-2.es.amazonaws.com
OPENSEARCH_USER=usuario
OPENSEARCH_PASSWORD=senha
# Índice padrão e whitelist de índices que o MCP pode consultar (CSV).
# Inclua notion_comments e notion_attachments para a Luna ler comentários e anexos dos chamados.
OPENSEARCH_INDEX=database_producao
OPENSEARCH_ALLOWED_INDICES=database_producao,notion_comments,notion_attachments
OPENSEARCH_VERIFY_CERTS=true
# Use SigV4/IAM em vez de usuário/senha (requer boto3 no MCP).
OPENSEARCH_USE_AWS_AUTH=false
AWS_REGION=us-east-2
LOG_LEVEL=INFO

# ============================================================
# MCP: postgres-mcp (banco de dados de produção — SOMENTE LEITURA)
# ============================================================
# URL do MCP de banco que a Luna consulta (transporte SSE, endpoint /sse).
# - No compose, deixe o padrão para usar o serviço postgres-mcp local.
# - Vazio desliga o MCP de banco (a Luna analisa só código + chamados).
MCP_POSTGRES_URL=http://postgres-mcp:8000/sse

# String de conexão de LEITURA usada pelo serviço postgres-mcp. Fica só no
# container do MCP (a Luna nunca recebe a credencial do banco). O modo
# --access-mode=restricted garante somente leitura (bloqueia escrita/DDL).
# Use, de preferência, um usuário de banco com permissão apenas de SELECT.
DATABASE_URI=postgresql://user:password@host:5432/dbname
